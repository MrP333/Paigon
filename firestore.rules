rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{uid} {

      // Read own document only
      allow read: if request.auth != null && request.auth.uid == uid;

      // Create own document — balanceCents must not be set by the client
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && !('balanceCents' in request.resource.data);

      // Update own document — balanceCents is server-only (Railway Admin SDK bypasses rules)
      // Dev accounts (platform owners) can still adjust balance for testing
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && (
                      !request.resource.data.diff(resource.data)
                        .affectedKeys().hasAny(['balanceCents', 'isDev'])
                      || request.auth.token.email in [
                           'pjgrimes930@gmail.com',
                           'contact@paigonco.com',
                           'cogrimes33@gmail.com'
                         ]
                    );

      // Match history subcollection — clients can read and create their own records
      // (balance is server-protected so fake records are cosmetic-only)
      match /matches/{matchId} {
        allow read:   if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid;
        allow update, delete: if false;
      }
    }

    // ── Leaderboard — public read, server writes only (Admin SDK bypasses rules)
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Usernames (uniqueness index) ───────────────────────────────────────────
    match /usernames/{username} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── Stripe events — server writes only, no client access ──────────────────
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // ── Recent activity feed — public read, authenticated create only ────────
    match /recentActivity/{entryId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Default: deny everything not explicitly allowed ────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
