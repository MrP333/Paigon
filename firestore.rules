rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function isAdminEmail() {
      return request.auth.token.email in [
        'pjgrimes930@gmail.com',
        'contact@paigonco.com',
        'cogrimes33@gmail.com'
      ];
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{uid} {

      allow read: if isOwner(uid);

      // New accounts: server-only fields must not be set by the client
      allow create: if isOwner(uid)
                    && !('balanceCents' in request.resource.data)
                    && !('isDev'        in request.resource.data)
                    && !('points'       in request.resource.data);

      // Updates: balanceCents/isDev/points are server-only (Railway Admin SDK bypasses rules)
      // Admin emails can touch any field for testing
      allow update: if isOwner(uid)
                    && (
                      !request.resource.data.diff(resource.data)
                        .affectedKeys().hasAny(['balanceCents', 'isDev', 'points'])
                      || isAdminEmail()
                    );

      // Match history: client may append entries, never modify or delete
      match /matches/{matchId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasAll(['game', 'won', 'createdAt'])
                      && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }

    // ── Leaderboard — public read, server writes only ─────────────────────────
    match /leaderboard/{uid} {
      allow read: if true;
      allow write: if false;
    }

    // ── Usernames (uniqueness index) ───────────────────────────────────────────
    match /usernames/{username} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── Stripe events — server only, no client access ─────────────────────────
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // ── Site stats — public read (homepage ticker), server writes only ─────────
    match /siteStats/{docId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Activity feed — public read, authenticated client creates only ─────────
    // Admin SDK (server) can also write here; client creates require key fields
    // and a server-issued timestamp to prevent backdating
    match /recentActivity/{entryId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['game', 'winner', 'createdAt'])
                    && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    // ── Tournaments — public read, server Admin SDK writes only ──────────────────
    match /tournaments/{tournamentId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Tournament schedules — authenticated read, server writes only ─────────────
    match /tournamentSchedules/{scheduleId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Default: deny everything not explicitly allowed ────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
